   "source": [
    "# 各科目点数を変数として定義\n",
    "japanese = 70\n",
    "math = 80\n",
    "english = 90\n",
    "\n",
    "# 平均点を計算\n",
    "average = (japanese + math + english) / 3\n",
    "\n",
    "# 結果を表示\n",
    "print(\" ３科目の平均点は \",average,\"点です\")"
   ]
  }
